# GateForge local environment — copy to .env and fill in values:
#   cp .env.example .env
#
# Then start:  ./scripts/local-up.sh
# Stop:        ./scripts/local-down.sh
# Reset DB:    podman-compose down -v

# --- 3scale Admin API (required for discovery / migration effort estimation) ---
THREESCALE_ADMIN_URL=https://3scale-admin.apps.example.com
THREESCALE_ACCESS_TOKEN=

# Optional: multiple 3scale tenants as JSON array
# THREESCALE_SOURCES=[{"id":"prod","label":"Production","adminUrl":"https://...","accessToken":"...","enabled":true}]

# --- LiteLLM / AI assistant (optional but recommended) ---
AI_ENDPOINT=https://litellm-prod.apps.maas.redhatworkshops.io/v1
AI_API_KEY=
AI_MODEL=openai/deepseek-r1-distill-qwen-14b

# --- OpenShift / Kubernetes (optional — not needed for Admin-API-only discovery) ---
# KUBE_API_URL=https://api.apps.example.com:6443
# KUBE_TOKEN=
CLUSTER_DOMAIN=apps.example.com

# --- Discovery mode (compose defaults: false / false — no cluster required) ---
THREESCALE_CRD_DISCOVERY=false
APICAST_DISCOVERY=false

# Enable cluster CRD/APICast discovery (read-only ClusterRole recommended; not cluster-admin):
# THREESCALE_CRD_DISCOVERY=true
# APICAST_DISCOVERY=true
# KUBE_API_URL=https://api.apps.example.com:6443
# KUBE_TOKEN=

# --- Advanced (Helm / multi-cluster) ---
# TARGET_CLUSTERS=
# ARGOCD_CLUSTER_DISCOVERY=false
